# Database
DB_PASSWORD=

# Local LLM for enrichment (Ollama — runs on GPU, zero API cost)
# If set, enrichment uses local GPU instead of Claude API
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b

# Intelligence Layer (Claude API — used for analysis/narrative when Ollama unavailable)
ANTHROPIC_API_KEY=
INTEL_DAILY_BUDGET_USD=10
INTEL_ANALYSIS_MODEL=claude-sonnet-4-6

# Shodan (Academic Lifetime)
SHODAN_API_KEY=

# Cloudflare Radar
CLOUDFLARE_API_TOKEN=

# ACLED (OAuth2 — email + password for token grant)
ACLED_EMAIL=
ACLED_PASSWORD=

# NASA FIRMS
FIRMS_MAP_KEY=

# AlienVault OTX
OTX_API_KEY=

# OpenSky (OAuth2 client credentials, optional — increases rate limits)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AIS Stream (aisstream.io — free account required for maritime tracking)
AISSTREAM_API_KEY=

# Global Fishing Watch (Bearer token — vessel monitoring)
GFW_API_TOKEN=

# Telegram MTProto (grammers — direct channel monitoring, replaces Bot API)
# Obtain API credentials at https://my.telegram.org/auth
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# SQLite session file path (persists auth across restarts)
TELEGRAM_SESSION_PATH=data/telegram.session
# For initial login only (set phone, restart, then set code and restart again):
# TELEGRAM_PHONE=+1234567890
# TELEGRAM_CODE=12345

# Exa (web search for supplementary situation context)
EXA_API_KEY=

# FAA NOTAM API (api.faa.gov — requires registration at FAA API portal)
FAA_NOTAM_CLIENT_ID=
FAA_NOTAM_CLIENT_SECRET=

# Vector Embeddings (BGE-M3 — semantic event clustering)
EMBEDDINGS_ENABLED=true
EMBEDDINGS_CACHE_DIR=
